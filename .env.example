# Шаблон секретов: скопируй в .env и заполни.
# Сам сервис читает токены из config.toml (см. config.example.toml);
# .env держим как удобное место хранить значения вне репозитория.

RUST_LOG=info

SOURCE_1_SLUG=expenses-bot
SOURCE_1_SPACE=expenses
SOURCE_1_BOT_TOKEN=123456:REPLACE_ME
SOURCE_1_TRANSCRIPTION_PROVIDER=none
# SOURCE_1_TRANSCRIPTION_TOKEN=sk-REPLACE_ME

